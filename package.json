{
  "name": "vg2",
  "version": "1.0.0",
  "description": "Voxel Game 2 Server",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:ci": "npm run build --workspace=@vg2/core && npm run build --workspace=@vg2/shared && npm run build --workspaces --workspace-concurrency=1",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "npm run typecheck --workspaces",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
}
